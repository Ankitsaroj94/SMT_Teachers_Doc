  "request": {
    "resourceId": "string",
    "date": "string"
  },
  "response": {
    "resourceId": "string",
    "resourceName": "string",
    "date": "string",
    "timeSlots": [
      {
        "time": "string",
        "available": "boolean"
      }
    ]
  },
  "example_response": {
    "resourceId": "c1",
    "resourceName": "Classroom 1",
    "date": "2025-08-19",
    "timeSlots": [
      { "time": "7:00 AM", "available": true },
      { "time": "7:30 AM", "available": true },
      { "time": "8:00 AM", "available": false },
      { "time": "8:30 AM", "available": true }
    ]
  }
}
